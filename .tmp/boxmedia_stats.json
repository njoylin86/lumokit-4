{
  "block_name": "lumo/stats-focus",
  "title": "Stats Focus",
  "html_template": "<section class=\"bg-teal-50 py-16\">\n  <div class=\"max-w-6xl mx-auto px-6\">\n    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n      <div class=\"bg-white rounded-2xl shadow-sm p-8\">\n        <h3 class=\"text-xl font-bold text-gray-900 mb-4\">{{focus_title}}</h3>\n        <p class=\"text-gray-500 text-sm leading-relaxed mb-6\">{{focus_text}}</p>\n        <a href=\"{{cta_link}}\" style=\"display:inline-block;background:#f472b6;color:#fff;font-weight:600;padding:12px 32px;border-radius:9999px;text-decoration:none;\">{{cta_text}}</a>\n      </div>\n      <div class=\"bg-white rounded-2xl shadow-sm p-8 flex flex-col justify-center gap-8\">\n        <div class=\"text-center\">\n          <p class=\"text-5xl font-bold text-gray-900\">{{stat_1_number}}</p>\n          <p class=\"text-gray-500 text-sm mt-1\">{{stat_1_label}}</p>\n        </div>\n        <div class=\"text-center\">\n          <p class=\"text-5xl font-bold text-gray-900\">{{stat_2_number}}</p>\n          <p class=\"text-gray-500 text-sm mt-1\">{{stat_2_label}}</p>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>",
  "schema": [
    { "name": "focus_title", "type": "text", "label": "Kortets rubrik", "default": "Google i fokus" },
    { "name": "focus_text", "type": "textarea", "label": "Kortets text", "default": "Som webbyrå Stockholm arbetar vi nästan uteslutande med Google-optimering av olika slag, vilket gör att det naturligt även hjälper era webbplatser." },
    { "name": "cta_text", "type": "text", "label": "Knapptext", "default": "LÅTER BRA, GE MIG OFFERT" },
    { "name": "cta_link", "type": "url", "label": "Knapplänk", "default": "#kontakt" },
    { "name": "stat_1_number", "type": "text", "label": "Statistik 1 – Siffra", "default": "10+" },
    { "name": "stat_1_label", "type": "text", "label": "Statistik 1 – Beskrivning", "default": "Års erfarenhet" },
    { "name": "stat_2_number", "type": "text", "label": "Statistik 2 – Siffra", "default": "1000+" },
    { "name": "stat_2_label", "type": "text", "label": "Statistik 2 – Beskrivning", "default": "Över 1000 nöjda kunder genom åren" }
  ]
}
