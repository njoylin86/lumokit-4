{"block_name": "lumo/vt-page-hero", "title": "Västertorp Sidhero (inner pages)", "html_template": "<section style=\"background:#0d0d0d;padding:80px 24px;\"><div style=\"max-width:72rem;margin:0 auto;\"><p style=\"font-size:0.72rem;font-weight:600;text-transform:uppercase;letter-spacing:0.14em;color:#00e676;margin:0 0 16px;\">{{eyebrow}}</p><h1 style=\"font-size:clamp(2rem,4vw,3.2rem);font-weight:700;color:#ffffff;margin:0 0 28px;line-height:1.1;max-width:640px;\">{{headline}}</h1><ul style=\"list-style:none;padding:0;margin:0 0 36px;display:flex;flex-direction:column;gap:10px;\"><li style=\"display:flex;align-items:center;gap:10px;color:#ffffff;font-size:1rem;\"><span class=\"material-symbols-outlined\" style=\"font-size:20px;color:#00e676;\">check_circle</span>{{punchline_1}}</li><li style=\"display:flex;align-items:center;gap:10px;color:#ffffff;font-size:1rem;\"><span class=\"material-symbols-outlined\" style=\"font-size:20px;color:#00e676;\">check_circle</span>{{punchline_2}}</li><li style=\"display:flex;align-items:center;gap:10px;color:#ffffff;font-size:1rem;\"><span class=\"material-symbols-outlined\" style=\"font-size:20px;color:#00e676;\">check_circle</span>{{punchline_3}}</li><li style=\"display:flex;align-items:center;gap:10px;color:#ffffff;font-size:1rem;\"><span class=\"material-symbols-outlined\" style=\"font-size:20px;color:#00e676;\">check_circle</span>{{punchline_4}}</li></ul><div style=\"display:flex;gap:16px;flex-wrap:wrap;\"><a href=\"{{cta_link}}\" style=\"display:inline-block;background:#00e676;color:#0d0d0d;font-weight:700;font-size:0.95rem;padding:14px 32px;border-radius:24px;text-decoration:none;\">{{cta_text}}</a><a href=\"{{cta_2_link}}\" style=\"display:inline-block;background:transparent;color:#ffffff;font-weight:600;font-size:0.95rem;padding:14px 32px;border-radius:24px;text-decoration:none;border:2px solid rgba(255,255,255,0.3);\">{{cta_2_text}}</a></div></div></section>", "schema": [{"name": "eyebrow", "type": "text", "label": "Etikett", "default": "Västertorp Tandkliniken"}, {"name": "headline", "type": "text", "label": "Rubrik", "default": "Behandling"}, {"name": "punchline_1", "type": "text", "label": "USP 1", "default": "Tid inom 24 timmar"}, {"name": "punchline_2", "type": "text", "label": "USP 2", "default": "Ingen remiss krävs"}, {"name": "punchline_3", "type": "text", "label": "USP 3", "default": "Öppet kvällar och helger"}, {"name": "punchline_4", "type": "text", "label": "USP 4", "default": "Tandvårdskort godkänt"}, {"name": "cta_text", "type": "text", "label": "Knapptext 1", "default": "Boka tid"}, {"name": "cta_link", "type": "url", "label": "Knapplänk 1", "default": "#"}, {"name": "cta_2_text", "type": "text", "label": "Knapptext 2", "default": "Ring oss"}, {"name": "cta_2_link", "type": "url", "label": "Knapplänk 2", "default": "#"}]}