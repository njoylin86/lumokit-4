{
  "block_name": "lumo/hero-section",
  "title": "Hero Section",
  "html_template": "<section class=\"bg-gradient-to-b from-cyan-100 to-teal-50 py-16 lg:py-24\">\n  <div class=\"max-w-6xl mx-auto px-6\">\n    <div class=\"flex flex-col lg:flex-row items-center gap-12\">\n      <div class=\"lg:w-1/2\">\n        <h1 class=\"text-5xl lg:text-6xl font-bold text-gray-900 leading-tight mb-2\">{{headline}}</h1>\n        <p class=\"text-xs uppercase tracking-widest text-gray-500 mb-6\">{{label}}</p>\n        <p class=\"text-gray-600 mb-8 max-w-md leading-relaxed\">{{body_text}}</p>\n        <a href=\"{{cta_link}}\" style=\"display:inline-block;border:2px solid #111827;color:#111827;font-weight:600;padding:12px 32px;border-radius:9999px;text-decoration:none;\">{{cta_text}}</a>\n      </div>\n      <div class=\"lg:w-1/2 flex justify-center\">\n        <img src=\"{{hero_image}}\" alt=\"Hero illustration\" class=\"w-full max-w-lg\">\n      </div>\n    </div>\n  </div>\n</section>",
  "schema": [
    {
      "name": "label",
      "type": "text",
      "label": "Övertitel (liten text ovanför rubriken)",
      "default": "ADS, SEO OCH WEBBDESIGN"
    },
    {
      "name": "headline",
      "type": "text",
      "label": "Huvudrubrik",
      "default": "Webbyrå Stockholm"
    },
    {
      "name": "body_text",
      "type": "textarea",
      "label": "Brödtext",
      "default": "Söker du en proffsig webbyrå i Stockholm? Välkommen till oss, din one stop shop för allt från SEO till webbdesign!"
    },
    {
      "name": "cta_text",
      "type": "text",
      "label": "Knapptext",
      "default": "GRATIS OFFERT DIREKT"
    },
    {
      "name": "cta_link",
      "type": "url",
      "label": "Knapplänk",
      "default": "#kontakt"
    },
    {
      "name": "hero_image",
      "type": "image",
      "label": "Illustration / Bild",
      "default": ""
    }
  ]
}
