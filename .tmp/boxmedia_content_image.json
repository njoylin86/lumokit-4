{
  "block_name": "lumo/content-image",
  "title": "Content with Image",
  "html_template": "<section class=\"bg-gradient-to-b from-teal-50 to-pink-50 py-16 lg:py-24\">\n  <div class=\"max-w-6xl mx-auto px-6\">\n    <div class=\"flex flex-col lg:flex-row items-center gap-12\">\n      <div class=\"lg:w-1/2 flex justify-center\">\n        <img src=\"{{section_image}}\" alt=\"Illustration\" class=\"w-full max-w-md\">\n      </div>\n      <div class=\"lg:w-1/2\">\n        <h2 class=\"text-3xl font-bold text-gray-900 mb-4\">{{headline}}</h2>\n        <p class=\"text-gray-600 text-sm leading-relaxed mb-8\">{{body_text}}</p>\n        <a href=\"{{cta_link}}\" style=\"display:inline-block;background:#f472b6;color:#fff;font-weight:600;padding:12px 32px;border-radius:9999px;text-decoration:none;\">{{cta_text}}</a>\n      </div>\n    </div>\n  </div>\n</section>",
  "schema": [
    { "name": "headline", "type": "text", "label": "Rubrik", "default": "Konvertering och data" },
    { "name": "body_text", "type": "textarea", "label": "Brödtext", "default": "Vår länkraft, design och konverteringsoptimering är byggd på många års research. Vi har stött och blött metoderna och vet vad som fungerar." },
    { "name": "cta_text", "type": "text", "label": "Knapptext", "default": "FÅ GRATIS OFFERT" },
    { "name": "cta_link", "type": "url", "label": "Knapplänk", "default": "#kontakt" },
    { "name": "section_image", "type": "image", "label": "Sektionsbild / Illustration", "default": "https://placehold.co/600x600" }
  ]
}
