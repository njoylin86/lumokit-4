{"block_name": "lumo/site-footer", "title": "Site Footer", "html_template": "<footer style=\"background:#0d0d0d;padding:64px 24px 0;\"><div style=\"max-width:72rem;margin:0 auto;\"><div style=\"display:grid;grid-template-columns:repeat(4,1fr);gap:40px;padding-bottom:48px;\"><div><p style=\"font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:#00e676;margin:0 0 16px;\">Klinik</p><ul style=\"list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:10px;\"><li><a href=\"/\" style=\"color:#9ca3af;font-size:0.88rem;text-decoration:none;\">Startsida</a></li><li><a href=\"/om-oss\" style=\"color:#9ca3af;font-size:0.88rem;text-decoration:none;\">Om oss</a></li><li><a href=\"/kontakta-oss\" style=\"color:#9ca3af;font-size:0.88rem;text-decoration:none;\">Kontakta oss</a></li></ul></div><div><p style=\"font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:#00e676;margin:0 0 16px;\">Behandlingar</p><ul style=\"list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:10px;\"><li><a href=\"/behandlingar/akuttandvard\" style=\"color:#9ca3af;font-size:0.88rem;text-decoration:none;\">Akuttandvård</a></li><li><a href=\"/behandlingar/kirurgi\" style=\"color:#9ca3af;font-size:0.88rem;text-decoration:none;\">Kirurgi</a></li></ul></div><div><p style=\"font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:#00e676;margin:0 0 16px;\">Kontakt</p><ul style=\"list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:10px;\"><li><a href=\"tel:{{site_phone}}\" style=\"color:#9ca3af;font-size:0.88rem;text-decoration:none;\">{{site_phone}}</a></li><li><a href=\"mailto:{{site_email}}\" style=\"color:#9ca3af;font-size:0.88rem;text-decoration:none;\">{{site_email}}</a></li></ul></div><div><p style=\"font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:#00e676;margin:0 0 16px;\">Adress</p><p style=\"color:#9ca3af;font-size:0.88rem;line-height:1.7;margin:0 0 16px;white-space:pre-line;\">{{site_address}}</p><p style=\"font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:#00e676;margin:0 0 8px;\">Öppettider</p><p style=\"color:#9ca3af;font-size:0.88rem;line-height:1.7;margin:0;white-space:pre-line;\">{{site_opening_hours}}</p></div></div><div style=\"border-top:1px solid rgba(255,255,255,0.08);\"></div><div style=\"display:flex;align-items:center;justify-content:space-between;padding:24px 0;\"><div style=\"display:flex;gap:20px;align-items:center;\"><a href=\"{{facebook_url}}\" style=\"color:#6b7280;font-size:0.8rem;text-decoration:none;\">Facebook</a><a href=\"{{instagram_url}}\" style=\"color:#6b7280;font-size:0.8rem;text-decoration:none;\">Instagram</a><a href=\"{{linkedin_url}}\" style=\"color:#6b7280;font-size:0.8rem;text-decoration:none;\">LinkedIn</a></div><p style=\"color:#4b5563;font-size:0.78rem;margin:0;\">© {{year}} {{site_company_name}}</p></div><div style=\"border-top:1px solid rgba(255,255,255,0.08);\"></div><div style=\"padding:24px 0 32px;\"><p style=\"font-family:'Space Grotesk',sans-serif;font-size:clamp(3rem,8vw,7rem);font-weight:700;color:#ffffff;margin:0;line-height:1;text-transform:uppercase;letter-spacing:-0.02em;opacity:0.15;\">{{logo_text}}</p></div></div></footer>", "schema": [{"name": "logo_text", "type": "text", "label": "Logotyptext", "default": "Mellanströms Tandklinik"}, {"name": "year", "type": "text", "label": "År", "default": "2025"}, {"name": "facebook_url", "type": "url", "label": "Facebook-länk", "default": "#"}, {"name": "instagram_url", "type": "url", "label": "Instagram-länk", "default": "#"}, {"name": "linkedin_url", "type": "url", "label": "LinkedIn-länk", "default": "#"}]}