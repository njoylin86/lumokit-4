{"block_name": "lumo/site-header", "title": "Site Header", "html_template": "<style>@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap');@import url('https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200');body,body *{font-family:'Inter',sans-serif!important;}body h1,body h2,body h3,body h4{font-family:'Space Grotesk',sans-serif!important;}</style><header style=\"background:#0d0d0d;padding:0 24px;position:sticky;top:0;z-index:999;\"><div style=\"max-width:72rem;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:68px;\"><a href=\"/\" style=\"font-family:'Space Grotesk',sans-serif;font-size:1.1rem;font-weight:700;color:#ffffff;text-decoration:none;text-transform:uppercase;letter-spacing:0.06em;\">{{logo_text}}</a><nav style=\"color:#ffffff;\">{{lumokit-primary}}</nav><a href=\"{{cta_link}}\" style=\"background:#00e676;color:#0d0d0d;font-weight:700;font-size:0.88rem;padding:10px 22px;border-radius:24px;text-decoration:none;white-space:nowrap;\">{{cta_text}}</a></div></header>", "schema": [{"name": "logo_text", "type": "text", "label": "Logotyptext", "default": "Mellanströms Tandklinik"}, {"name": "lumokit-primary", "type": "nav_menu", "label": "Primär meny"}, {"name": "cta_text", "type": "text", "label": "Knapptext", "default": "Boka tid"}, {"name": "cta_link", "type": "url", "label": "Knapplänk", "default": "#tdl-booking-widget"}]}