      "block_name": "lumo/site-footer",
      "title": "Site Footer",
      "html_template": "<footer style=\"background:#0D1714;padding:72px 24px 0;\"><div style=\"max-width:74rem;margin:0 auto;\"><div style=\"display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;padding-bottom:56px;\"><div><div style=\"display:flex;align-items:center;gap:10px;margin-bottom:20px;\"><div style=\"width:32px;height:32px;background:#C8A26A;border-radius:50%;display:flex;align-items:center;justify-content:center;\"><span style=\"color:#0D1714;font-size:14px;font-weight:800;\">L</span></div><span style=\"font-family:'Space Grotesk',sans-serif;font-size:1rem;font-weight:700;color:#ffffff;\">Lumo Dental</span></div><p style=\"font-size:0.875rem;color:rgba(255,255,255,0.4);line-height:1.8;margin:0 0 24px;max-width:260px;\">Modern tandvård med personlig touch — i hjärtat av Östermalm sedan 2009.</p><div style=\"display:flex;gap:10px;\"><a href=\"#\" style=\"width:36px;height:36px;background:rgba(255,255,255,0.06);border-radius:50%;display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:0.78rem;color:rgba(255,255,255,0.5);\">in</a><a href=\"#\" style=\"width:36px;height:36px;background:rgba(255,255,255,0.06);border-radius:50%;display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:0.78rem;color:rgba(255,255,255,0.5);\">ig</a></div></div><div><p style=\"font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:#C8A26A;margin:0 0 20px;\">Behandlingar</p><ul style=\"list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:12px;\"><li><a href=\"#\" style=\"color:rgba(255,255,255,0.45);font-size:0.875rem;text-decoration:none;\">Undersökning</a></li><li><a href=\"#\" style=\"color:rgba(255,255,255,0.45);font-size:0.875rem;text-decoration:none;\">Estetisk tandvård</a></li><li><a href=\"#\" style=\"color:rgba(255,255,255,0.45);font-size:0.875rem;text-decoration:none;\">Tandreglering</a></li><li><a href=\"#\" style=\"color:rgba(255,255,255,0.45);font-size:0.87