    {
      "block_name": "lumo/ld-services",
      "title": "Lumo Dental — Behandlingar",
      "html_template": "<section id=\"behandlingar\" style=\"background:#F0EDE7;padding:100px 24px;\"><div style=\"max-width:74rem;margin:0 auto;\"><div style=\"display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:64px;\"><div><p style=\"font-size:0.68rem;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:#C8A26A;margin:0 0 16px;display:flex;align-items:center;gap:10px;\"><span style=\"width:24px;height:1px;background:#C8A26A;display:inline-block;\"></span>Vad vi gör</p><h2 style=\"font-family:'Space Grotesk',sans-serif;font-size:clamp(2rem,4vw,3.2rem);font-weight:700;color:#13201D;margin:0;line-height:1.08;letter-spacing:-0.02em;\">Våra behandlingar</h2></div><a href=\"/behandlingar\" style=\"color:#2C574A;font-size:0.875rem;font-weight:600;text-decoration:none;border-bottom:2px solid #2C574A;padding-bottom:2px;white-space:nowrap;\">Se alla →</a></div><div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:16px;\"><div style=\"background:#ffffff;border-radius:20px;padding:36px;\"><div style=\"width:48px;height:48px;background:#F0EDE7;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:24px;font-size:1.4rem;\">🦷</div><h3 style=\"font-family:'Space Grotesk',sans-serif;font-size:1.08rem;font-weight:700;color:#13201D;margin:0 0 12px;\">Undersökning</h3><p style=\"font-size:0.875rem;color:#6D6A67;line-height:1.75;margin:0 0 24px;\">Grundlig hälsokontroll av tänder, tandkött och käke — grunden för ett friskt leende.</p><a href=\"#\" style=\"font-size:0.82rem;font-weight:600;color:#2C574A;text-decoration:none;\">Läs mer →</a></div><div style=\"background:#2C574A;border-radius:20px;padding:36px;\"><div style=\"width:48px;height:48px;background:rgba(255,255,255,0.14);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:24px;font-size:1.4rem;\">✨</div><h3 style=\"font-family:'Space Grotesk',sans-serif;font-size:1.08rem;font-weight:700;color:#ffffff;margin:0 0 12px;\">Estetisk tandvård</h3><p style=\"font-size:0.875rem;color:rgba(255,255,255,0.68);line-height:1.75;margin:0 0 24px;\">Porslinsveneer, blekning och komposit — för det leende du alltid drömt om.</p><a href=\"#\" style=\"font-size:0.82rem;font-weight:600;color:#C8A26A;text-decoration:none;\">Läs mer →</a></div><div style=\"background:#ffffff;border-radius:20px;padding:36px;\"><div style=\"width:48px;height:48px;background:#F0EDE7;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:24px;font-size:1.4rem;\">📐</div><h3 style=\"font-family:'Space Grotesk',sans-serif;font-size:1.08rem;font-weight:700;color:#13201D;margin:0 0 12px;\">Tandreglering</h3><p style=\"font-size:0.875rem;color:#6D6A67;line-height:1.75;margin:0 0 24px;\">Invisalign och traditionell reglering — diskret och effektiv för alla åldrar.</p><a href=\"#\" style=\"font-size:0.82rem;font-weight:600;color:#2C574A;text-decoration:none;\">Läs mer →</a></div><div style=\"background:#ffffff;border-radius:20px;padding:36px;\"><div style=\"width:48px;height:48px;background:#F0EDE7;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:24px;font-size:1.4rem;\">🔬</div><h3 style=\"font-family:'Space Grotesk',sans-serif;font-size:1.08rem;font-weight:700;color:#13201D;margin:0 0 12px;\">Implantat</h3><p style=\"font-size:0.875rem;color:#6D6A67;line-height:1.75;margin:0 0 24px;\">Permanenta lösningar för saknade tänder med naturligt utseende och känsla.</p><a href=\"#\" style=\"font-size:0.82rem;font-weight:600;color:#2C574A;text-decoration:none;\">Läs mer →</a></div><div style=\"background:#ffffff;border-radius:20px;padding:36px;\"><div style=\"width:48px;height:48px;background:#F0EDE7;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:24px;font-size:1.4rem;\">⚡</div><h3 style=\"font-family:'Space Grotesk',sans-serif;font-size:1.08rem;font-weight:700;color:#13201D;margin:0 0 12px;\">Akuttandvård</h3><p style=\"font-size:0.875rem;color:#6D6A67;line-height:1.75;margin:0 0 24px;\">Akut smärta kräver snabb hjälp. Vi reserverar alltid tid för akuta fall samma dag.</p><a href=\"#\" style=\"font-size:0.82rem;font-weight:600;color:#2C574A;text-decoration:none;\">Läs mer →</a></div><div style=\"background:#13201D;border-radius:20px;padding:36px;display:flex;flex-direction:column;justify-content:space-between;min-height:220px;\"><p style=\"font-family:'Space Grotesk',sans-serif;font-size:1.35rem;font-weight:700;color:#ffffff;margin:0 0 16px;line-height:1.3;\">Hittar du inte vad du söker?</p><a href=\"/kontakt\" style=\"background:#C8A26A;color:#13201D;font-weight:700;font-size:0.85rem;padding:14px 24px;border-radius:50px;text-decoration:none;text-align:center;display:block;\">Kontakta oss</a></div></div></div></section>",
