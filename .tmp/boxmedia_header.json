{
  "block_name": "lumo/site-header",
  "title": "Site Header",
  "html_template": "<header style=\"background:#fff;border-bottom:1px solid #f0f0f0;\">\n  <div class=\"max-w-6xl mx-auto px-6 py-4 flex items-center justify-between\">\n    <a href=\"/\" style=\"font-weight:800;font-size:1.25rem;color:#111827;text-decoration:none;letter-spacing:-0.02em;\">{{logo_text}}</a>\n    <nav style=\"display:flex;align-items:center;gap:2rem;\">{{lumokit-primary}}</nav>\n  </div>\n  <style>nav a{font-size:0.8rem;font-weight:500;color:#374151;text-decoration:none;letter-spacing:0.05em;text-transform:uppercase;}nav li{list-style:none;display:inline-block;margin:0;}</style>\n</header>",
  "schema": [
    { "name": "logo_text", "type": "text", "label": "Logotyptext", "default": "BOXMEDIA" },
    { "name": "lumokit-primary", "type": "nav_menu", "label": "Primär meny" }
  ]
}
