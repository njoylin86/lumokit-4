    {
      "block_name": "lumo/vt-how",
      "title": "Västertorp Så funkar det",
      "html_template": "<section style=\"background:#ffffff;padding:80px 24px;\"><div style=\"max-width:72rem;margin:0 auto;\"><h2 style=\"font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:700;color:#0d0d0d;margin:0 0 56px;line-height:1.1;\">{{heading}}</h2><div style=\"display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;\"><div><img src=\"{{image}}\" alt=\"\" style=\"width:100%;aspect-ratio:3/4;object-fit:cover;border-radius:16px;display:block;\"></div><div style=\"display:flex;flex-direction:column;gap:16px;\"><div style=\"background:#f5f5f5;border-radius:14px;padding:28px;\"><p style=\"font-size:0.95rem;color:#333333;line-height:1.75;margin:0;\">{{card_1_text}}</p></div><div style=\"background:#f5f5f5;border-radius:14px;padding:28px;\"><p style=\"font-size:0.95rem;color:#333333;line-height:1.75;margin:0;\">{{card_2_text}}</p></div></div></div></div></section>",
      "schema": [
        {
          "name": "heading",
          "type": "text",
          "label": "Rubrik",
          "default": "Tandvård i Västertorp\n— hur funkar det?"
        },
        {
          "name": "image",
          "type": "image",
          "label": "Foto (vänster)"
        },
        {
          "name": "card_1_text",
          "type": "textarea",
          "label": "Kort 1 – Text",
          "default": "Vi tar emot hela familjen och erbjuder allt från basundersökning till avancerad kirurgi. Du bokar enkelt din tid online och vi ser till att du alltid känner dig välkommen."
        },
        {
          "name": "card_2_text",
          "type": "textarea",
          "label": "Kort 2 – Text",
          "default": "Hos oss betalar du bara för det du behöver. Vi har inga dolda avgifter och alltid transparenta priser. Din munhälsa är vårt prioritet."
        }
      ]
    },
