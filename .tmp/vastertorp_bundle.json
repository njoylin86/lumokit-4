      "title": "Västertorp FAQ",
      "html_template": "<section style=\"background:#ffffff;padding:80px 24px;\"><div style=\"max-width:72rem;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;\"><div><img src=\"{{image}}\" alt=\"\" style=\"width:100%;aspect-ratio:3/4;object-fit:cover;border-radius:16px;display:block;margin-bottom:24px;\"><a href=\"{{cta_link}}\" style=\"display:inline-block;background:#00e676;color:#0d0d0d;font-weight:700;font-size:0.82rem;padding:12px 24px;border-radius:24px;text-decoration:none;\">{{cta_text}}</a></div><div><p style=\"font-size:0.72rem;font-weight:600;text-transform:uppercase;letter-spacing:0.12em;color:#888888;margin:0 0 8px;\">{{eyebrow}}</p><h2 style=\"font-size:clamp(1.8rem,3vw,2.4rem);font-weight:700;color:#0d0d0d;margin:0 0 40px;line-height:1.15;\">{{heading}}</h2><div style=\"display:flex;flex-direction:column;\"><div style=\"padding:20px 0;border-bottom:1px solid #eeeeee;\"><div style=\"display:flex;justify-content:space-between;align-items:center;\"><p style=\"font-size:0.92rem;font-weight:500;color:#0d0d0d;margin:0;\">{{q1}}</p><span style=\"font-size:1.2rem;color:#888888;flex-shrink:0;margin-left:16px;\">+</span></div><p style=\"font-size:0.88rem;color:#555555;margin:12px 0 0;line-height:1.7;\">{{a1}}</p></div><div style=\"padding:20px 0;border-bottom:1px solid #eeeeee;\"><div style=\"display:flex;justify-content:space-between;align-items:center;\"><p style=\"font-size:0.92rem;font-weight:500;color:#0d0d0d;margin:0;\">{{q2}}</p><span style=\"font-size:1.2rem;color:#888888;flex-shrink:0;margin-left:16px;\">+</span></div><p style=\"font-size:0.88rem;color:#555555;margin:12px 0 0;line-height:1.7;\">{{a2}}</p></div><div style=\"padding:20px 0;border-bottom:1px solid #eeeeee;\"><div style=\"display:flex;justify-content:space-between;align-items:center;\"><p style=\"font-size:0.92rem;font-weight:500;color:#0d0d0d;margin:0;\">{{q3}}</p><span style=\"font-size:1.2rem;color:#888888;flex-shrink:0;margin-left:16px;\">+</span></div><p style=\"font-size:0.88rem;color:#555555;margin:12px 0 0;line-height:1.7;\">{{a3}}</p></div><div style=\"padding:20px 0;\"><div style=\"display:flex;justify-content:space-between;align-items:center;\"><p style=\"font-size:0.92rem;font-weight:500;color:#0d0d0d;margin:0;\">{{q4}}</p><span style=\"font-size:1.2rem;color:#888888;flex-shrink:0;margin-left:16px;\">+</span></div><p style=\"font-size:0.88rem;color:#555555;margin:12px 0 0;line-height:1.7;\">{{a4}}</p></div></div></div></div></section>",
