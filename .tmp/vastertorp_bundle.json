    {
      "block_name": "lumo/vt-hero",
      "title": "Västertorp Hero (startsida)",
      "html_template": "<section style=\"background:#ffffff;overflow:hidden;\"><div style=\"max-width:72rem;margin:0 auto;padding:0 24px;display:grid;grid-template-columns:1fr 1fr;min-height:520px;gap:40px;align-items:center;\"><div style=\"padding:64px 0;\"><div style=\"background:#f5f5f5;border-radius:16px;padding:32px;margin-bottom:40px;display:inline-block;max-width:380px;\"><p style=\"font-size:0.72rem;font-weight:600;text-transform:uppercase;letter-spacing:0.12em;color:#888888;margin:0 0 12px;\">{{card_label}}</p><p style=\"font-size:clamp(2rem,4vw,3rem);font-weight:700;color:#0d0d0d;margin:0 0 12px;line-height:1.1;\">{{card_headline}}</p><p style=\"font-size:0.9rem;color:#555555;margin:0 0 24px;line-height:1.7;\">{{card_text}}</p><a href=\"{{cta_link}}\" style=\"display:inline-block;background:#00e676;color:#0d0d0d;font-weight:700;font-size:0.82rem;padding:12px 24px;border-radius:24px;text-decoration:none;\">{{cta_text}}</a></div><div><h1 style=\"font-size:clamp(2rem,4vw,3rem);font-weight:700;color:#0d0d0d;margin:0 0 4px;line-height:1.1;\">{{headline}}</h1><p style=\"font-size:clamp(1.5rem,3vw,2.2rem);font-weight:400;font-style:italic;color:#333333;margin:0;line-height:1.2;\">{{subheadline}}</p></div></div><div style=\"height:520px;margin-right:-24px;\"><img src=\"{{image}}\" alt=\"\" style=\"width:100%;height:100%;object-fit:cover;display:block;\"></div></div></section>",
      "schema": [
        {
          "name": "card_label",
          "type": "text",
          "label": "Kort – Etikett",
          "default": "Välkommen"
        },
        {
          "name": "card_headline",
