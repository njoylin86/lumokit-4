{
  "site_name": "Västertorp Tandkliniken",
  "components": [
    {
      "block_name": "lumo/site-header",
      "title": "Site Header",
      "html_template": "<style>@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap');body,body *{font-family:'Inter',sans-serif!important;}body h1,body h2,body h3,body h4{font-family:'Space Grotesk',sans-serif!important;}</style><header style=\"background:#0d0d0d;\"><div style=\"max-width:72rem;margin:0 auto;padding:16px 24px;display:flex;align-items:center;justify-content:space-between;\"><a href=\"/\" style=\"text-decoration:none;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1.1rem;color:#ffffff;letter-spacing:0.06em;text-transform:uppercase;\">{{logo_text}}</a><nav>{{lumokit-primary}}</nav><a href=\"{{cta_link}}\" style=\"display:inline-block;background:#00e676;color:#0d0d0d;font-weight:700;font-size:0.82rem;padding:10px 22px;border-radius:24px;text-decoration:none;white-space:nowrap;\">{{cta_text}}</a></div><style>header nav a{font-size:0.85rem;font-weight:500;color:#ffffff;text-decoration:none;}header nav .sub-menu{background:#1a1a1a;border:1px solid #333333;border-radius:8px;box-shadow:0 4px 16px rgba(0,0,0,0.4);}header nav .sub-menu a{color:#ffffff;}</style></header>",
      "schema": [
        {
          "name": "logo_text",
          "type": "text",
          "label": "Logotyptext",
          "default": "Västertorp Tandkliniken"
        },
        {
          "name": "lumokit-primary",
          "type": "nav_menu",
          "label": "Primär meny"
        },
        {
          "name": "cta_text",
          "type": "text",
          "label": "Knapptext",
          "default": "Boka tid"
        },
        {
          "name": "cta_link",
          "type": "url",
          "label": "Knapplänk",
          "default": "/kontakta-oss"
        }
      ]
    },
    {
      "block_name": "lumo/site-footer",
      "title": "Site Footer",
      "html_template": "<footer style=\"background:#0d0d0d;color:#888888;\"><div style=\"max-width:72rem;margin:0 auto;padding:64px 24px 40px;\"><div style=\"display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;margin-bottom:56px;\"><div><p style=\"font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:0.12em;color:#555555;margin:0 0 16px;\">Kliniken</p><div style=\"display:flex;flex-direction:column;gap:10px;\"><a href=\"/om-oss\" style=\"font-size:0.85rem;color:#888888;text-decoration:none;\">Om oss</a><a href=\"/akuttandvard\" style=\"font-size:0.85rem;color:#888888;text-decoration:none;\">Akuttandvård</a><a href=\"/kirurgi\" style=\"font-size:0.85rem;color:#888888;text-decoration:none;\">Kirurgi</a><a href=\"/kontakta-oss\" style=\"font-size:0.85rem;color:#888888;text-decoration:none;\">Kontakt</a></div></div><div><p style=\"font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:0.12em;color:#555555;margin:0 0 16px;\">Kontakt</p><div style=\"display:flex;flex-direction:column;gap:10px;\"><a href=\"tel:{{phone}}\" style=\"font-size:0.85rem;color:#888888;text-decoration:none;\">{{phone}}</a><a href=\"mailto:{{email}}\" style=\"font-size:0.85rem;color:#888888;text-decoration:none;\">{{email}}</a></div></div><div><p style=\"font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:0.12em;color:#555555;margin:0 0 16px;\">Öppettider</p><p style=\"font-size:0.85rem;color:#888888;margin:0 0 6px;line-height:1.6;\">{{hours_weekday}}</p><p style=\"font-size:0.85rem;color:#888888;margin:0;line-height:1.6;\">{{hours_weekend}}</p></div><div><p style=\"font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:0.12em;color:#555555;margin:0 0 16px;\">Adress</p><p style=\"font-size:0.85rem;color:#888888;margin:0;line-height:1.7;\">{{address}}</p></div></div><div style=\"border-top:1px solid #222222;padding-top:32px;display:flex;align-items:center;justify-content:space-between;\"><span style=\"font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1.3rem;color:#ffffff;letter-spacing:0.06em;text-transform:uppercase;\">{{logo_text}}</span><p style=\"font-size:0.78rem;color:#555555;margin:0;\">{{copyright}}</p></div></div></footer>",
