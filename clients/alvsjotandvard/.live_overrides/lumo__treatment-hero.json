  "html_template": "<section class=\"treatment-hero\"> <div class=\"th-mobile-bg\" style=\"background-image:url({{hero_image}});\"></div> <div class=\"th-inner\"> <div class=\"eyebrow\" style=\"margin-bottom:20px;color:var(--sage-600);\">{{eyebrow}}</div> <div class=\"th-grid\"> <div class=\"th-left\"> <h1>{{title}}<br><em>{{title_italic}}</em></h1> <div> <p class=\"lead th-lead\">{{ingress}}</p> <div class=\"th-bullets\"> <div class=\"th-bullet\"><svg class=\"th-num\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><polyline points=\"20 6 9 17 4 12\"/></svg>{{bullet_1}}</div> <div class=\"th-bullet\"><svg class=\"th-num\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><polyline points=\"20 6 9 17 4 12\"/></svg>{{bullet_2}}</div> <div class=\"th-bullet\"><svg class=\"th-num\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><polyline points=\"20 6 9 17 4 12\"/></svg>{{bullet_3}}</div> <div class=\"th-bullet\"><svg class=\"th-num\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><polyline points=\"20 6 9 17 4 12\"/></svg>{{bullet_4}}</div> </div> <div class=\"th-ctas\" style=\"display:flex;gap:12px;\"> <a href=\"#tdl-booking-widget\" class=\"btn btn-primary\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"/><path d=\"M16 2v4M8 2v4M3 10h18\"/></svg>Boka tid</