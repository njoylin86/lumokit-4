  "html_template": "<section class=\"mc-section\" style=\"background:#fafafabd;\"> <div class=\"container-wide\"> <div class=\"mc-hdr\"> <div class=\"eyebrow\" style=\"margin-bottom:16px;\">{{eyebrow}}</div> <h2>{{heading}}</h2> </div> <div class=\"mc-grid\"> <article class=\"mc-item\"><div class=\"mc-name-row\"><h3 class=\"mc-name\">{{m1_name}}</h3><span class=\"mc-badge\">{{m1_badge}}</span></div><div class=\"mc-meta\"><div class=\"mc-meta-row\"><span class=\"mc-meta-label\">Tid</span><span class=\"mc-meta-val\">{{m1_time}}</span></div><div class=\"mc-meta-row\"><span class=\"mc-meta-label\">Effekt</span><span class=\"mc-meta-val mc-meta-val--accent\">{{m1_effect}}</span></div></div><p class=\"mc-desc\">{{m1_desc}}</p></article><article class=\"mc-item\"><div class=\"mc-name-row\"><h3 class=\"mc-name\">{{m2_name}}</h3><span class=\"mc-badge\">{{m2_badge}}</span></div><div class=\"mc-meta\"><div class=\"mc-meta-row\"><span class=\"mc-meta-label\">Tid</span><span class=\"mc-meta-val\">{{m2_time}}</span></div><div class=\"mc-meta-row\"><span class=\"mc-meta-label\">Effekt</span><span class=\"mc-meta-val mc-meta-val--accent\">{{m2_effect}}</span></div></div><p class=\"mc-desc\">{{m2_desc}}</p></article><article class=\"mc-item\"><div class=\"mc-name-row\"><h3 class=\"mc-name\">{{m3_name}}</h3><span class=\"mc-badge\">{{m3_badge}}</span></div><div class=\"mc-meta\"><div class=\"mc-meta-row\"><span class=\"mc-meta-label\">Tid</span><span class=\"mc-meta-val\">{{m3_time}}</span></div><div class=\"mc-meta-row\"><span class=\"mc-meta-label\">Effekt</span><span class=\"mc-meta-val mc-meta-val--accent\">{{m3_effect}}</span></div></div><p class=\"mc-desc\">{{m3_desc}}</p></article> </div> </div> </section>",
