    },
    {
      "name": "m1_badge",
      "type": "text",
      "label": "Metod 1 – badge",
      "default": "Snabbt resultat"
    },
    {
      "name": "m1_time",
      "type": "text",
      "label": "Metod 1 – tid",
      "default": "60–90 min"
    },
    {
      "name": "m1_effect",
      "type": "text",
      "label": "Metod 1 – effekt",
