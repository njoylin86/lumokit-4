    {
      "name": "eyebrow",
      "type": "text",
      "label": "Etikett",
      "default": "Blekningsmetoder"
    },
    {
      "name": "heading",
      "type": "text",
      "label": "Rubrik",
      "default": "Välj rätt metod för ditt leende."
    },
    {
