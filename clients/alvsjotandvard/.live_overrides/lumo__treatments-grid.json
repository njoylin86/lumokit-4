{
  "block_name": "lumo/treatments-grid",
  "title": "Behandlingar – grid",
  "html_template": "<section class=\"treatments-section section\"> <div class=\"container-wide\"> <div class=\"treatments-hdr\"> <div> <div class=\"eyebrow\">Behandlingar</div> <h2>Ett komplett utbud, under ett tak.</h2> </div> <div class=\"treatments-hdr-meta\"> <p>Från regelbunden tandvård till specialistbehandlingar — alltid utförda på plats av våra egna tandläkare.</p> <a href=\"#tdl-booking-widget\" class=\"treatments-hdr-link\">Till bokningskalendern →</a> </div> </div> <div class=\"treatments-grid\"> <a href=\"{{card_1_url}}\" class=\"treatment-card\"> <div class=\"tc-bg\" style=\"background-image:url({{card_1_image}});\"></div> <div class=\"tc-overlay\"></div> <div class=\"tc-body\"> <div class=\"tc-top\"> <div class=\"tc-count\">{{card_1_count}}</div> <div class=\"tc-badge\" data-clinic-status><span class=\"tc-badge-dot\"></span><span data-clinic-status-label>·</span></div> </div> <div><div class=\"tc-name\">{{card_1_name}}</div></div> </div> </a> <a href=\"{{card_2_url}}\" class=\"treatment-card\"> <div class=\"tc-bg\" style=\"background-image:url({{site_url}}/wp-content/uploads/2026/05/implantat-1-1.jpg);\"></div> <div class=\"tc-overlay\"></div> <div class=\"tc-body\"> <div class=\"tc-top\"> <div class=\"tc-count\">{{card_2_count}}</div> </div> <div><div class=\"tc-name\">{{card_2_name}}</div></div> </div> </a> <a href=\"{{card_3_url}}\" class=\"treatment-card\"> <div class=\"tc-bg\" style=\"background-image:url({{card_3_image}});\"></div> <div class=\"tc-overlay\"></div> <div class=\"tc-body\"> <div class=\"tc-top\"> <div class=\"tc-count\">{{card_3_count}}</div> </div> <div><div class=\"tc-name\">{{card_3_name}}</div></div> </div> </a> <a href=\"{{card_4_url}}\" class=\"treatment-card\"> <div class=\"tc-bg\" style=\"background-image:url({{card_4_image}});\"></div> <div class=\"tc-overlay\"></div> <div class=\"tc-body\"> <div class=\"tc-top\"> <div class=\"tc-count\">{{card_4_count}}</div> </div> <div><div class=\"tc-name\">{{card_4_name}}</div></div> </div> </a> <a href=\"{{card_5_url}}\" class=\"treatment-card\"> <div class=\"tc-bg\" style=\"background-image:url({{card_5_image}});\"></div> <div class=\"tc-overlay\"></div> <div class=\"tc-body\"> <div class=\"tc-top\"> <div class=\"tc-count\">{{card_5_count}}</div> </div> <div><div class=\"tc-name\">{{card_5_name}}</div></div> </div> </a> <a href=\"{{card_6_url}}\" class=\"treatment-card\"> <div class=\"tc-bg\" style=\"background-image:url({{card_6_image}});\"></div> <div class=\"tc-overlay\"></div> <div class=\"tc-body\"> <div class=\"tc-top\"> <div class=\"tc-count\">{{card_6_count}}</div> </div> <div><div class=\"tc-name\">{{card_6_name}}</div></div> </div> </a> <a href=\"{{card_7_url}}\" class=\"treatment-card\"> <div class=\"tc-bg\" style=\"background-image:url({{card_7_image}});\"></div> <div class=\"tc-overlay\"></div> <div class=\"tc-body\"> <div class=\"tc-top\"> <div class=\"tc-count\">{{card_7_count}}</div> </div> <div><div class=\"tc-name\">{{card_7_name}}</div></div> </div> </a> <a href=\"{{card_8_url}}\" class=\"treatment-card\"> <div class=\"tc-bg\" style=\"background-image:url({{card_8_image}});\"></div> <div class=\"tc-overlay\"></div> <div class=\"tc-body\"> <div class=\"tc-top\"> <div class=\"tc-count\">{{card_8_count}}</div> </div> <div><div class=\"tc-name\">{{card_8_name}}</div></div> </div> </a></div> </div> </section> <script> (function(){ var DAYS = ['mån','tis','ons','tor','fre','lör']; var HOURS = {1:[420,1200],2:[420,1200],3:[420,1200],4:[420,1200],5:[420,1020],6:[540,900]}; /* Mån-Tor 07-20, Fre 07-17, Lör 09-15, Sön stängt. Minuter sedan midnatt. */ function nowStockholm(){ try { var fmt = new Intl.DateTimeFormat('en-US',{timeZone:'Europe/Stockholm',weekday:'short',hour:'2-digit',minute:'2-digit',hour12:false}); var parts = {}; fmt.formatToParts(new Date()).forEach(function(p){ parts[p.type] = p.value; }); var wkMap = {Sun:0,Mon:1,Tue:2,Wed:3,Thu:4,Fri:5,Sat:6}; var day = wkMap[parts.weekday]; var hour = parseInt(parts.hour,10); if (hour === 24) hour = 0; var min = hour*60 + parseInt(parts.minute,10); return { day: day, min: min }; } catch(e) { return null; } } function nextOpen(day, mins){ for(var i=0;i<7;i++){ var d = (day+i)%7; var h = HOURS[d]; if(!h) continue; if(i===0){ if(mins < h[0]) return { day: d, min: h[0], today: true }; continue; } return { day: d, min: h[0], today: false }; } return null; } function fmt(min){ var h=Math.floor(min/60), m=min%60; return (h<10?'0':'')+h+':'+(m<10?'0':'')+m; } function update(){ var t = nowStockholm(); if(!t) return; var h = HOURS[t.day]; var isOpen = false; if (h) { if (t.min >= h[0]) { if (t.min < h[1]) { isOpen = true; } } } document.querySelectorAll('[data-clinic-status]').forEach(function(el){ var lbl = el.querySelector('[data-clinic-status-label]'); if(isOpen){ el.classList.remove('is-closed'); if(lbl) lbl.textContent = 'Öppet nu'; } else { var n = nextOpen(t.day, t.min); el.classList.add('is-closed'); if(lbl){ if(n){ lbl.innerHTML = n.today ? ('Öppnar<br>' + fmt(n.min)) : ('Öppnar ' + DAYS[n.day-1] + '<br>' + fmt(n.min)); } else { lbl.textContent = 'Stängt'; } } } }); } if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',update); else update(); setInterval(update, 60000); })(); </script> <style>.tc-badge.is-closed{background:rgba(60,60,60,.92);}.tc-badge.is-closed .tc-badge-dot{background:#9a9a9a;}</style>",
