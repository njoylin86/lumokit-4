  "html_template": "<section class=\"treatment-hero\"> <div class=\"th-mobile-bg\" style=\"background-image:url({{hero_image}});\"></div> <div class=\"th-inner\"> <h1 class=\"eyebrow\" style=\"margin-bottom:20px;color:var(--sage-600);\">Tandvårdsrädsla, Älvsjö</h1> <div class=\"th-grid\"> <div class=\"th-left\"> <p class=\"th-heading\">{{title}}<br><em>{{title_italic}}</em></p> <div> <p class=\"lead th-lead\">{{ingress}}</p> <div class=\"th-bullets\"> <div class=\"th-bullet\"><svg class=\"th-num\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><polyline points=\"20 6 9 17 4 12\"/></svg>{{bullet_1}}</div> <div class=\"th-bullet\"><svg class=\"th-num\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><polyline points=\"20 6 9 17 4 12\"/></svg>{{bullet_2}}</div> <div class=\"th-bullet\"><svg class=\"th-num\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><polyline points=\"20 6 9 17 4 12\"/></svg>{{bullet_3}}</div> <div class=\"th-bullet\"><svg class=\"th-num\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><polyline points=\"20 6 9 17 4 12\"/></svg>{{bullet_4}}</div> </div> <div class=\"th-ctas\" style=\"display:flex;gap:12px;\"> <a href=\"#tdl-booking-widget\" class=\"btn btn-primary\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"/><path d=\"M16 2v4M8 2v4M3 10h18\"/></svg>Boka tid</a> <a href=\"tel:+46812854555\" class=\"btn btn-ghost\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z\"/></svg>Ring oss</a> </div> <div class=\"th-review-widget\">[trustindex data-widget-id=0771e9d71a88743f97661278b10]</div> </div> </div> <div class=\"th-right\"> <div class=\"th-photo\" style=\"background-image:url({{hero_image}});\"></div> <div class=\"th-stat\"> <div class=\"th-stat-label\">{{stat_label}}</div> <div class=\"th-stat-value\">{{stat_value}}</div> <div class=\"th-stat-sub\">{{stat_sub}}</div> </div> </div> </div> </div> </section>",
